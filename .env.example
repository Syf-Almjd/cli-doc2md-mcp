# Claude Token Saver MCP Config Defaults
# Copy this file to .env inside this directory to apply local parameters

# MCP Port configuration (Only relevant if transport is upgraded to SSE / HTTP)
PORT=3001

# Logging levels (options: info, debug, error, warn)
LOG_LEVEL=info

# Default Optimizer Settings
# These defaults apply when arguments are omitted in parse_local_file requests
DEFAULT_STRIP_IMAGES=true
DEFAULT_STRIP_LINKS=true
DEFAULT_COLLAPSE_WHITESPACE=true
DEFAULT_COMPACT_TABLES=true
